# Servidor
NODE_ENV=development
PORT=3000
API_VERSION=v1

# CORS
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Microservicio IA
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT_MS=60000

# Archivos
UPLOAD_MAX_SIZE_MB=50
UPLOAD_TEMP_DIR=uploads/temp

# Logging
LOG_LEVEL=debug
LOG_DIR=logs